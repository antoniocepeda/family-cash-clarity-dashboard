NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only Firebase Admin values for local development.
# On Firebase App Hosting/Cloud Run, prefer Application Default Credentials
# and set only FIREBASE_PROJECT_ID when needed.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server-only Plaid values, if Plaid sync routes are added/enabled.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
